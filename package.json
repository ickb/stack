{
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "pnpm run -C packages/tests test && vitest",
    "test:ci": "pnpm run -C packages/tests test && vitest run",
    "test:cov": "vitest run --coverage",
    "build:prepare": "pnpm -r install",
    "build": "pnpm -r run build",
    "build:all": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "format": "pnpm -r run format",
    "sync:config": "pnpm -r  --filter !./packages/bot --filter !./packages/interface --filter !./packages/utils -c exec 'for f in .gitignore .npmignore .prettierignore prettier.config.cjs tsconfig.json; do cp ../utils/$f .; done'",
    "change": "pnpm changeset",
    "version": "pnpm changeset version",
    "publish": "pnpm publish -r",
    "docs": "typedoc"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^9.36.0",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "^9.36.0",
    "prettier": "^3.6.2",
    "typedoc": "0.28.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.45.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.8.1"
}