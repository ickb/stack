{
  "name": "@ickb/utils",
  "version": "1001.0.0",
  "description": "General utilities built on top of CCC",
  "keywords": [
    "ickb",
    "ccc",
    "ckb",
    "blockchain"
  ],
  "author": "phroi",
  "license": "MIT",
  "homepage": "https://ickb.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ickb/stack.git"
  },
  "bugs": {
    "url": "https://github.com/ickb/stack/issues"
  },
  "sideEffects": false,
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "api-extractor": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "vitest",
    "test:ci": "vitest run",
    "build": "rm -fr dist && tsgo -p tsconfig.build.json && node ../../scripts/tooling/build/rewrite-dts-imports.ts dist",
    "lint:api": "api-extractor run --local",
    "lint": "pnpm --workspace-root exec eslint --max-warnings=0 packages/utils/src packages/utils/test",
    "clean": "rm -fr dist"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "dependencies": {
    "@ckb-ccc/core": "catalog:"
  }
}
