{
  "name": "@ickb/node-utils",
  "version": "1001.0.0",
  "private": true,
  "description": "Shared Node utilities for iCKB apps",
  "keywords": [
    "ickb",
    "ccc",
    "ckb",
    "blockchain"
  ],
  "author": "phroi",
  "license": "MIT",
  "homepage": "https://ickb.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/ickb/stack"
  },
  "bugs": {
    "url": "https://github.com/ickb/stack/issues"
  },
  "sideEffects": false,
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest",
    "test:ci": "vitest run",
    "lint": "pnpm --workspace-root exec eslint --max-warnings=0 packages/node-utils/src packages/node-utils/test"
  },
  "dependencies": {
    "@ckb-ccc/core": "catalog:",
    "@ickb/utils": "workspace:*"
  },
  "devDependencies": {
    "@ickb/testkit": "workspace:*",
    "@types/node": "catalog:"
  }
}
