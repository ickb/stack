  "compilerOptions": {
    "noEmit": false,
    "removeComments": false,
    "rewriteRelativeImportExtensions": true,
    "rootDir": "src",
    "outDir": "dist",
    "sourceRoot": "../src"
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/*_test_support.ts"]
}
